# Copia este archivo a ".env" en esta misma carpeta y pon tus valores reales.
# Consigue tu clave en https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-proj-tu-clave-aqui

# gpt-4o-mini = más económico, suficiente para chat y recetas
# gpt-4o = mejor calidad, necesario para análisis de imágenes (tickets)
OPENAI_MODEL=gpt-4o-mini

# Puerto (por defecto 3000)
PORT=3000
